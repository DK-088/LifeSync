# ==========================================
# LifeSync AI - Environment Configuration Template
# Duplicate this file as '.env' and fill in your settings.
# ==========================================

# ------------------------------------------
# 🚀 Server Configuration
# ------------------------------------------
# The port the backend server will listen on
PORT=5000

# The environment mode: 'development', 'production', or 'test'
NODE_ENV=development

# ------------------------------------------
# 💾 Database Configuration
# ------------------------------------------
# Connection string for MongoDB (Local instance or MongoDB Atlas URL)
MONGO_URI=mongodb://localhost:27017/lifesync

# ------------------------------------------
# 🔐 Authentication (JWT Token Settings)
# ------------------------------------------
# Secret key used to sign access tokens (Keep this safe!)
JWT_SECRET=your_access_token_secret_key_here
# Lifespan duration for access tokens (e.g., '15m', '1h', '7d')
JWT_EXPIRES_IN=7d

# Secret key used to sign refresh tokens
JWT_REFRESH_SECRET=your_refresh_token_secret_key_here
# Lifespan duration for refresh tokens
JWT_REFRESH_EXPIRES_IN=30d

# ------------------------------------------
# 🛡️ Encryption Configuration
# ------------------------------------------
# A secure 256-bit key used for field-level encryption (UPI accounts, phone numbers, etc.)
AES_SECRET_KEY=your_aes_256_encryption_key_here

# ------------------------------------------
# 🤖 AI & Machine Learning APIs
# ------------------------------------------
# API Key for OpenAI services (GPT-4o-mini, Whisper transcription)
OPENAI_API_KEY=your_openai_api_key_here

# API Key for Google Gemini services
GEMINI_API_KEY=your_gemini_api_key_here

# ------------------------------------------
# 📁 File Uploads Settings
# ------------------------------------------
# Maximum upload size for receipt scans or voice records (in Bytes)
MAX_FILE_SIZE=5242880

# The relative/absolute directory path to write uploads to
UPLOAD_PATH=uploads/

# ------------------------------------------
# ⏱️ Rate Limiting Configuration
# ------------------------------------------
# Window timeframe for rate limiting (in milliseconds)
RATE_LIMIT_WINDOW_MS=900000

# Maximum number of API requests allowed within the window frame per IP
RATE_LIMIT_MAX_REQUESTS=100

# ------------------------------------------
# 🌐 Cross-Origin Resource Sharing (CORS)
# ------------------------------------------
# The URL of the allowed frontend client interface
CLIENT_URL=http://localhost:3000

# ------------------------------------------
# 📧 SMTP Configuration (Email Delivery & OTPs)
# ------------------------------------------
# The SMTP server host address (e.g., smtp.gmail.com, smtp.mailtrap.io)
SMTP_HOST=smtp.gmail.com

# The SMTP server port (e.g., 465 for SSL, 587 for TLS)
SMTP_PORT=465

# The username/email for email server authorization
SMTP_USER=your_email_address_here

# The password or App Password for email server authorization
SMTP_PASS=your_email_app_password_here

# The email address shown in the 'From' header field
FROM_EMAIL=noreply@lifesync.ai

# The display name shown in the 'From' header field
FROM_NAME=LifeSync AI
